{
  "name": "Dual Threshold",
  "version": "1.0",
  "author": "Joaquin Pérez & Oscar Muñoz Ferriz",
  "description": "Guided LT1/LT2 lactate threshold",
  "type": "feature",
  "usage": "workout",
  "modificationTime": 1780681223,
  "in": [
    {
      "name": "HeartRate",
      "source": "/Activity/Move/-1/HeartRate/Current",
      "type": "subscribe"
    },
    {
      "name": "Speed",
      "source": "/Activity/Current/Speed",
      "type": "subscribe"
    },
    {
      "name": "Power",
      "source": "/Activity/Current/Power3s",
      "type": "subscribe"
    },
    {
      "name": "MaxHR",
      "source": "/Settings/User/MaxHR",
      "type": "get"
    }
  ],
  "out": [
    {
      "name": "lt1HR"
    },
    {
      "name": "lt2HR"
    },
    {
      "name": "lt1Pace"
    },
    {
      "name": "lt2Pace"
    },
    {
      "name": "lt2Power"
    },
    {
      "name": "hrTargetNum",
      "log": false,
      "shownName": "HR Target Range"
    },
    {
      "name": "stateNum",
      "log": false,
      "shownName": "State Index"
    },
    {
      "name": "timeRemaining",
      "log": false,
      "shownName": "Time Remaining"
    },
    {
      "name": "testModeNum",
      "log": false,
      "shownName": "Test Mode"
    },
    {
      "name": "dfaCurrent",
      "log": false,
      "shownName": "Current DFA a1"
    },
    {
      "name": "hrZoneNum",
      "log": false,
      "shownName": "HR Zone Index"
    }
  ],
  "template": [
    {
      "name": "t.html"
    },
    {
      "name": "debug.html"
    },
    {
      "name": "results.html"
    },
    {
      "name": "alert.html"
    }
  ]
}